{
  "Connections": {
    "tempdb-sql": {
      "Engine": "SqlServer",
      "ConnectionString": "Server=localhost;Database=tempdb;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        // stdio MCP: stdout carries the JSON-RPC frame. standardErrorFromLevel
        // "Verbose" routes EVERY level of this Console sink to stderr so no log
        // byte lands on stdout and corrupts the protocol. Do NOT remove this key
        // or "fix" the sink back to stdout. See mcp-dotnet KB §2.2. The code half
        // of this guarantee is in Program.cs (bootstrap-logger stderr routing +
        // builder.Logging.ClearProviders()).
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "standardErrorFromLevel": "Verbose"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dbmcp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Resilience": {
    // Retry is OFF by default. A local single-caller MCP prefers to surface
    // deadlocks (1205) and let the user re-run rather than silently paper
    // over them. When enabled, the predicate is transient-only — permanent
    // errors (207 invalid column, 208 invalid object, 2627 PK violation, etc.)
    // never retry. SQL error -2 (command timeout) is explicitly NOT transient
    // for our purposes — retrying a timed-out query burns another full timeout
    // window for no gain. See SqlServerEngine.TransientSqlErrorNumbers.
    "Retry":   { "Enabled": false, "MaxAttempts": 3, "BaseDelayMs": 200 },

    // Polly timeout is the outer safety net of a staggered pair. It exists
    // NOT as a generic "runaway query guard" but as an honest advertisement
    // of the MCP transport's ceiling: Claude Code has its own tool-response
    // timeout, SSE keepalive has a ceiling, and the request-response nature
    // of MCP is fundamentally incompatible with hour-long queries. When this
    // fires, it diagnoses "you're using the wrong tool for this job" at the
    // right layer with a clean error instead of leaking out as a mystery
    // client disconnect. DO NOT DELETE this timeout thinking "but it's a
    // local service." That reasoning is exactly the trap this comment exists
    // to prevent. See also Database.CommandTimeoutSeconds — Polly's effective
    // timeout is CommandTimeoutSeconds + 5, a deliberate stagger so the DB
    // engine cancels the query cleanly before Polly unwinds. Expert override:
    // set Enabled=false AND Database.CommandTimeoutSeconds=0 to run unbounded
    // fire-and-forget procs whose results the MCP client will never see.
    "Timeout": { "Enabled": true }
  },

  "Database": {
    // Per-query command timeout in seconds, threaded through every Dapper call
    // site in DatabaseService. This is the ONLY server-side safety mechanism in
    // DbMcp — there is NO row cap, NO pre-flight query rewriting, and NO
    // in-loop result truncation. The reader returns whatever the query produced,
    // bounded only by this wall-clock guardrail. Result-size discipline lives at
    // the caller layer (workspace game rule G16): Edan knows table size before
    // fetching and defaults every row-fetching query to TOP 10 / LIMIT 10 unless
    // explicitly justified. This server trusts that discipline by design.
    //
    // 43 seconds is chosen as an honest reflection of the MCP transport's real
    // ceiling (see Resilience.Timeout comment): Claude Code's tool-response
    // timeout, SSE keepalive, and the request-response shape of MCP all make
    // hour-long queries the wrong tool anyway. 43s is "long enough to answer any
    // question you should be asking this tool, short enough that accidents
    // surface fast as a clean SqlException timeout instead of as mystery hangs."
    //
    // Paired with Polly: Polly's timeout fires at CommandTimeoutSeconds + 5
    // (= 48s effective), so the DB engine cancels the query first and raises a
    // normal SqlException/NpgsqlException timeout, leaving Polly as an outer
    // safety net in case cancellation doesn't propagate in time. See
    // SqlServerEngine.BuildResiliencePipeline and PostgresEngine equivalent.
    //
    // Set to 0 for infinite (expert override — see Resilience.Timeout comment).
    // Do NOT raise this back toward 115+ "to be safe" — longer timeouts don't
    // make unbounded queries safer, they just make accidents hang longer.
    "CommandTimeoutSeconds": 43
  }
}
